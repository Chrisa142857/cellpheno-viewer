
# MinIO / S3 server hosting the NIS results.
# Defaults to http://localhost:8080 (the local Docker MinIO from the README) when unset.
VITE_MINIO_ORIGIN = http://localhost:8080
VITE_MINIO_BUCKET = brainmapp14

# Optional: on-demand zoom service (Lightsheet repo: nis_ondemand_viewer).
# When set, zoom cubes are cropped on request instead of read from MinIO.
# Leave empty to keep the pre-materialized MinIO behaviour.
# VITE_ZOOM_API_ORIGIN = http://localhost:8090
